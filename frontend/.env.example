# Runtime services on the shared Docker network
DATABASE_URL=postgresql://nolimitflix_user:<password>@postgres:5432/nolimitflix_db
REDIS_URL=redis://redis:6379/0
MEDIA_ROOT=/app/media

# Public media base URL
# Build-time note: changing NEXT_PUBLIC_* values requires rebuilding the frontend image.
NEXT_PUBLIC_MEDIA_URL=https://nolimitflix.com/media
NEXT_PUBLIC_APP_URL=https://nolimitflix.com
NEXT_PUBLIC_TMDB_API_KEY=
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Legacy direct-upload flow still references this until those routes are removed.
NEXT_PUBLIC_CLOUDFRONT_URL=

# Application essentials
ADMIN_PASSWORD=<change-me>
AUTH_SECRET=<generate-a-random-secret>
