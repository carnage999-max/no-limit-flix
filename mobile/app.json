{
  "expo": {
    "name": "No Limit Flix",
    "slug": "no-limit-flix",
    "scheme": [
      "nolimitflix",
      "com.googleusercontent.apps.200339607199-vk7n3ldiu504i3nk2unrm19p8a8rjjh2",
      "com.googleusercontent.apps.200339607199-chpctcu36kegq5ll0jjp0od0i8ca3fpr"
    ],
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nolimitflix.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow No Limit Flix to access your photos so you can choose a profile picture.",
        "LSApplicationQueriesSchemes": [
          "vlc",
          "infuse"
        ]
      }
    },
    "android": {
      "package": "com.nolimitflix.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "nolimitflix"
            },
            {
              "scheme": "com.googleusercontent.apps.200339607199-vk7n3ldiu504i3nk2unrm19p8a8rjjh2"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-video",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "nolimitflix",
          "organization": "nolimitflix"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ae07b6bc-80f3-44ef-ae7f-00a7c8b152f0"
      }
    }
  }
}
